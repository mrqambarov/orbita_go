# Orbita Go Backend — Environment Variables
# Bu faylni .env ga nusxalang va qiymatlarni to'ldiring

# ─── Server ───────────────────────────────────────────
PORT=3001
NODE_ENV=production   # development | production
# Admin panel JWT tokenlarini imzolash uchun kalit (openssl rand -hex 32)
ADMIN_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET

# ─── JWT (Muhim: kuchli random string ishlating) ──────
# Misol: openssl rand -hex 64
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET

# ─── Email webhook (mail_pipe.php) ────────────────────
# openssl rand -hex 32
EMAIL_WEBHOOK_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET

# ─── Load-test rate-limit bypass (faqat development) ──
# Bo'sh qoldiring — production'da hech qachon o'rnatmang
LOAD_TEST_BYPASS_KEY=

# ─── Database ─────────────────────────────────────────
# SQLite (development):
# DATABASE_URL="file:./orbita_go.db"

# PostgreSQL (production):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/orbita_go?schema=public"
DATABASE_URL="file:./orbita_go.db"

# ─── SMS Provider (Eskiz.uz) ──────────────────────────
# OTP SMS yuborish uchun
SMS_EMAIL=
SMS_PASSWORD=

# ─── CORS ─────────────────────────────────────────────
# Flutter web uchun (agar web versiya bo'lsa)
# Vergul bilan ajrating: ALLOWED_ORIGINS=https://app.orbitago.uz,https://admin.orbitago.uz
ALLOWED_ORIGINS=

# ─── Cloudflare Tunnel ────────────────────────────────
# api.orbitago.uz -> localhost:PORT
# Tunnel sozlash: cloudflared tunnel create orbita-go
